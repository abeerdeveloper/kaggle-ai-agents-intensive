{
  "mcpServers": {
    "google-developer-knowledge": {
      "command": "npx",
      "args": [
        "-y",
        "@google/developer-knowledge-mcp-server"
      ],
      "env": {
        "GOOGLE_API_KEY": "YOUR_API_KEY_HERE"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN"
      }
    }
  }
}
